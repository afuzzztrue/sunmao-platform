.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F0E8;
}

.chat-list {
  flex: 1;
  padding: 24rpx 20rpx;
}

.msg-row-user {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 24rpx;
}

.msg-row-ai {
  display: flex;
  justify-content: flex-start;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3E2723, #5D4037);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.avatar-icon {
  font-size: 22rpx;
  color: #D4A45A;
  font-weight: bold;
}

.msg-bubble {
  max-width: 78%;
  padding: 22rpx 26rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-all;
}

.msg-bubble-user {
  background: #3E2723;
  color: #FFFFFF;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(62,39,35,0.10);
}

.msg-bubble-ai {
  background: #FFFFFF;
  color: #1A1A1A;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(62,39,35,0.06);
}

.loading-bubble {
  padding: 28rpx 36rpx;
}

.loading-dots {
  display: flex;
  gap: 10rpx;
  justify-content: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 9999rpx;
  background: #9B8E85;
  animation: dot-pulse 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes dot-pulse {
  0%, 80%, 100% {
    transform: scale(0.4);
    opacity: 0.3;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(62,39,35,0.04);
}

.input-field {
  flex: 1;
  height: 72rpx;
  background: #F5F0E8;
  border-radius: 9999rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}

.send-btn {
  background: #D4A45A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: bold;
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn[disabled] {
  background: #C9C1B9;
  color: #FFFFFF;
}
