/**index.wxss - 榫卯首页 v2.0 抖音风 (2026-06-24)**/
/**改造范围: 仅本页样式, 不影响 app.wxss 等全局**/

.page {
  background: var(--color-bg);
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* ========== 顶部横滑 tab (sticky) ========== */
.top-tabs {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  background: var(--color-bg);
  height: 88rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.menu-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 40rpx;
  color: var(--color-text);
  line-height: 1;
}

.tabs-scroll {
  flex: 1;
  white-space: nowrap;
  height: 88rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 20rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.tab-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  letter-spacing: 1rpx;
  transition: color 0.2s ease;
}

.tab-item.active .tab-text {
  color: var(--color-text);
  font-weight: 700;
  font-size: 34rpx;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 36rpx;
  height: 5rpx;
  background: linear-gradient(90deg, #E5B97A 0%, #D8584B 100%);
  border-radius: 3rpx;
}

.tab-badge {
  position: absolute;
  top: 16rpx;
  right: 12rpx;
  width: 12rpx;
  height: 12rpx;
  background: #D8584B;
  border-radius: 50%;
}

.search-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon-text {
  font-size: 36rpx;
  color: var(--color-text);
  line-height: 1;
}

/* ========== 搜索浮层 ========== */
.search-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.25s ease, visibility 0.25s;
}

.search-modal.show {
  visibility: visible;
  opacity: 1;
}

.search-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.search-modal-body {
  position: relative;
  background: var(--color-bg);
  padding: 24rpx 30rpx 40rpx;
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.search-modal-body .search-bar {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
  height: 76rpx;
  padding: 0 28rpx;
  border: 1rpx solid var(--color-border);
}

.search-modal-body .search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.45;
}

.search-modal-body .search-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-cancel {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.hot-keywords {
  margin-top: 32rpx;
}

.hot-keywords-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 16rpx;
}

.hot-keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-keyword {
  padding: 10rpx 24rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-round);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ========== 轮播图 ========== */
.banner-wrapper {
  padding: 20rpx 24rpx 12rpx;
}

.banner {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background: linear-gradient(
    to top,
    rgba(62, 39, 35, 0.5) 0%,
    rgba(62, 39, 35, 0.15) 50%,
    transparent 100%
  );
}

/* ========== 双列瀑布流 ========== */
.waterfall {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 24rpx 0;
  gap: 20rpx;
}

.waterfall-col {
  flex: 0 0 calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.waterfall-card {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid var(--color-border);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.waterfall-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.waterfall-img {
  width: 100%;
  display: block;
  background: linear-gradient(135deg, #F5F0E8 0%, #E8E0D0 100%);
}

.waterfall-body {
  padding: 16rpx 18rpx 18rpx;
}

.waterfall-title {
  font-size: 26rpx;
  color: var(--color-text);
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: 1rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 12rpx;
}

.waterfall-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.waterfall-author {
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 1rpx;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.waterfall-likes {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.waterfall-heart {
  font-size: 22rpx;
  color: #D8584B;
  margin-right: 6rpx;
  line-height: 1;
}

.waterfall-likes-num {
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 0.5rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
  letter-spacing: 1rpx;
}
