/**index.wxss - 榫卯首页主题样式**/

.page {
  background: var(--color-bg);
  min-height: 100vh;
  padding-bottom: 48rpx;
}

/* ========== 搜索框 ========== */
.search-bar {
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-bar-inner {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
  height: 76rpx;
  padding: 0 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.45;
}

.search-input {
  flex: 1;
  height: 76rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-muted);
}

.remind-icon {
  width: 56rpx;
  height: 56rpx;
  margin-left: 24rpx;
}

/* ========== 轮播图 ========== */
.banner-wrapper {
  padding: 8rpx 30rpx;
  margin-bottom: 8rpx;
}

.banner {
  width: 100%;
  height: 380rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 220rpx;
  background: linear-gradient(
    to top,
    rgba(62, 39, 35, 0.58) 0%,
    rgba(62, 39, 35, 0.18) 50%,
    transparent 100%
  );
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 0 36rpx 36rpx;
}

/* ========== 模块区域 ========== */
.module-section {
  padding: 36rpx 24rpx;
}

.module-list {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}

.module-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.hexagon {
  width: 108rpx;
  height: 124rpx;
  background: var(--color-bg-card);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: var(--shadow-sm);
}

.hexagon-inner {
  position: absolute;
  width: 92rpx;
  height: 106rpx;
  background: linear-gradient(150deg, var(--color-primary) 0%, #5D4037 100%);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  opacity: 0.07;
}

.module-icon {
  width: 56rpx;
  height: 56rpx;
  position: relative;
  z-index: 1;
}

.module-text {
  margin-top: 18rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* ========== 热门内容 ========== */
.hot-section {
  padding: 4rpx 30rpx 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-accent {
  width: 6rpx;
  height: 32rpx;
  background: var(--color-accent);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

.more-btn {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text-muted);
  padding: 8rpx 12rpx;
}

.arrow-icon {
  width: 22rpx;
  height: 22rpx;
  margin-left: 6rpx;
  opacity: 0.55;
}

.hot-scroll {
  white-space: nowrap;
}

.hot-item {
  display: inline-flex;
  flex-direction: column;
  width: 270rpx;
  margin-right: 20rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--color-bg-card);
  box-shadow: var(--shadow-sm);
}

.hot-item:last-child {
  margin-right: 30rpx;
}

.hot-img-wrap {
  width: 270rpx;
  height: 210rpx;
  overflow: hidden;
  position: relative;
}

.hot-img {
  width: 100%;
  height: 100%;
}

.hot-img-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 56rpx;
  background: linear-gradient(to top, rgba(62, 39, 35, 0.28), transparent);
}

.hot-item-label {
  padding: 14rpx 16rpx 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ========== 内容卡片 ========== */
.content-section {
  padding: 4rpx 30rpx;
}

.content-card {
  margin-bottom: 28rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--color-border);
}

.card-img-wrap {
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  position: relative;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-img-tag {
  position: absolute;
  left: 24rpx;
  top: 24rpx;
  background: rgba(62, 39, 35, 0.72);
  color: var(--color-bg);
  padding: 6rpx 22rpx;
  border-radius: var(--radius-round);
  font-size: 22rpx;
  letter-spacing: 2rpx;
  backdrop-filter: blur(6rpx);
}

.card-body {
  padding: 30rpx 28rpx 34rpx;
}

.card-tags {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.tag {
  background: linear-gradient(135deg, rgba(212, 164, 90, 0.14) 0%, rgba(212, 164, 90, 0.06) 100%);
  color: var(--color-accent);
  padding: 8rpx 22rpx;
  border-radius: var(--radius-round);
  font-size: 23rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(212, 164, 90, 0.18);
}

.location {
  font-size: 24rpx;
  color: var(--color-text-muted);
  letter-spacing: 1rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 14rpx;
  display: block;
  letter-spacing: 3rpx;
  line-height: 1.3;
}

.card-divider {
  width: 48rpx;
  height: 3rpx;
  background: var(--color-accent);
  border-radius: 2rpx;
  margin-bottom: 18rpx;
  opacity: 0.55;
}

.card-desc {
  font-size: 27rpx;
  color: var(--color-text-secondary);
  line-height: 1.78;
  letter-spacing: 1rpx;
  text-align: justify;
}
