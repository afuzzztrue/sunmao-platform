<!-- index.wxml - 榫卯首页 v2.0 抖音风 -->
<!-- 改造日期: 2026-06-24 -->
<!-- 改造范围: 仅 UI, 不动后端 API, 不动 4 Tab 结构 -->

<!-- WXS 工具: 数字格式化 (1.2w / 1.5k) -->
<wxs module="utils">
module.exports = {
  formatCount: function(num) {
    if (!num) return '0';
    if (num >= 10000) return (num/10000).toFixed(1) + 'w';
    if (num >= 1000) return (num/1000).toFixed(1) + 'k';
    return num + '';
  }
};
</wxs>

<view class="page">

  <!-- ========== 顶部横滑 tab (sticky) ========== -->
  <view class="top-tabs">
    <view class="menu-btn" bindtap="onTapMenu">
      <text class="menu-icon">☰</text>
    </view>

    <scroll-view
      scroll-x
      class="tabs-scroll"
      enhanced
      show-scrollbar="{{false}}"
      scroll-with-animation
      scroll-into-view="tab-{{currentTab}}"
    >
      <view
        wx:for="{{topTabs}}"
        wx:key="key"
        id="tab-{{item.key}}"
        class="tab-item {{currentTab === item.key ? 'active' : ''}}"
        bindtap="onSwitchTab"
        data-key="{{item.key}}"
      >
        <text class="tab-text">{{item.label}}</text>
        <view wx:if="{{item.badge}}" class="tab-badge"></view>
      </view>
    </scroll-view>

    <view class="search-btn" bindtap="onTapSearch">
      <text class="search-icon-text">🔍</text>
    </view>
  </view>

  <!-- 6/29: 搜索浮层已移除, 点击搜索图标直接跳转 global-search 页面 -->

  <!-- ========== 轮播图 ========== -->
  <view class="banner-wrapper">
    <swiper
      class="banner"
      indicator-dots
      indicator-color="rgba(255,255,255,0.4)"
      indicator-active-color="#E5B97A"
      autoplay
      circular
    >
      <swiper-item wx:for="{{bannerList}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill" class="banner-img" />
        <view class="banner-overlay"></view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ========== 双列瀑布流 (核心) ========== -->
  <view class="waterfall">
    <view class="waterfall-col">
      <view
        class="waterfall-card"
        wx:for="{{leftList}}"
        wx:key="articleId"
        bindtap="onTapCard"
        data-id="{{item.articleId}}"
      >
        <image
          class="waterfall-img"
          src="{{item.coverImage}}"
          mode="widthFix"
          lazy-load="{{true}}"
        />
        <view class="waterfall-body">
          <text class="waterfall-title">{{item.title}}</text>
          <view class="waterfall-meta">
            <text class="waterfall-author">@{{item.userId || '榫卯'}}</text>
            <view class="waterfall-likes">
              <text class="waterfall-heart">♥</text>
              <text class="waterfall-likes-num">{{utils.formatCount(item.viewCount)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="waterfall-col">
      <view
        class="waterfall-card"
        wx:for="{{rightList}}"
        wx:key="articleId"
        bindtap="onTapCard"
        data-id="{{item.articleId}}"
      >
        <image
          class="waterfall-img"
          src="{{item.coverImage}}"
          mode="widthFix"
          lazy-load="{{true}}"
        />
        <view class="waterfall-body">
          <text class="waterfall-title">{{item.title}}</text>
          <view class="waterfall-meta">
            <text class="waterfall-author">@{{item.userId || '榫卯'}}</text>
            <view class="waterfall-likes">
              <text class="waterfall-heart">♥</text>
              <text class="waterfall-likes-num">{{utils.formatCount(item.viewCount)}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 空状态 ========== -->
  <view class="empty-state" wx:if="{{!loading && leftList.length === 0 && rightList.length === 0}}">
    <text class="empty-icon">🪵</text>
    <text class="empty-text">暂无内容，下拉刷新试试</text>
  </view>

  <!-- 自定义 tabBar (抖音式, 中间 + 号) -->
  <custom-tab-bar />

</view>
