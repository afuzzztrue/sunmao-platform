page{background:var(--color-bg,#F5F0E8)}

.container{padding:0;background:var(--color-bg,#F5F0E8);min-height:100vh}

.page-header{padding:36rpx 32rpx 24rpx}
.page-title{font-size:40rpx;font-weight:700;color:var(--color-text,#1A1A1A)}

/* 固定头部：搜索框 + tab 滚动条 始终贴在顶部 */
.sticky-header{position:sticky;top:0;z-index:10;background:var(--color-bg-card,#FFFFFF);box-shadow:0 4rpx 12rpx rgba(62,39,35,0.06)}

/* 搜索跳转框：点击整条 bar 跳转到独立搜索页面 */
.search-bar{padding:0 24rpx 20rpx;background:transparent}
.search-input{display:flex;align-items:center;background:var(--color-bg,#F5F0E8);border-radius:var(--radius-round,9999rpx);padding:18rpx 32rpx;font-size:26rpx;color:var(--color-text-muted,#9B8E85);border:2rpx solid transparent;box-sizing:border-box}
.search-icon{font-size:28rpx;margin-right:12rpx;line-height:1}
.search-placeholder{font-size:26rpx;color:var(--color-text-muted,#9B8E85)}

/* 二级 tab 横向滚动条 —— 与商城 shop 风格保持一致 */
.category-scroll{white-space:nowrap;padding:0 24rpx 20rpx;background:transparent;box-shadow:none}
.cat-scroll-inner{display:inline-flex;gap:12rpx;align-items:center}
.cat-item{display:inline-flex;align-items:center;justify-content:center;padding:14rpx 26rpx;font-size:26rpx;color:var(--color-text-muted,#9B8E85);font-weight:500;border-radius:var(--radius-md,16rpx);background:rgba(212,164,90,0.06);flex-shrink:0;transition:all 0.2s}
.cat-item.active{color:#FFFFFF;background:var(--color-accent,#D4A45A);font-weight:600;box-shadow:0 2rpx 8rpx rgba(212,164,90,0.3)}

.order-list{padding:24rpx 24rpx 40rpx}

.order-card{background:var(--color-bg-card,#FFFFFF);border-radius:var(--radius-md,20rpx);padding:28rpx 32rpx;margin-bottom:20rpx;box-shadow:var(--shadow-sm,0 2rpx 8rpx rgba(62,39,35,0.06));transition:all 0.3s ease}
.order-card.highlight{animation:orderHighlight 2.5s ease}
@keyframes orderHighlight{
  0%{box-shadow:0 0 0 0 rgba(212,164,90,0.55),0 2rpx 8rpx rgba(62,39,35,0.06);transform:scale(1.015)}
  10%{box-shadow:0 0 0 16rpx rgba(212,164,90,0.30),0 4rpx 16rpx rgba(212,164,90,0.20);transform:scale(1.015)}
  70%{box-shadow:0 0 0 16rpx rgba(212,164,90,0.30),0 4rpx 16rpx rgba(212,164,90,0.20);transform:scale(1.015)}
  100%{box-shadow:0 0 0 0 rgba(212,164,90,0.55),0 2rpx 8rpx rgba(62,39,35,0.06);transform:scale(1)}
}

.card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14rpx}
.order-name{font-size:32rpx;font-weight:600;color:var(--color-text,#1A1A1A);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.qty-badge{display:inline-flex;align-items:center;justify-content:center;min-width:48rpx;height:36rpx;padding:0 12rpx;border-radius:var(--radius-sm,12rpx);background:rgba(212,164,90,0.12);margin-left:16rpx;flex-shrink:0}
.qty-badge text{font-size:22rpx;color:var(--color-accent,#D4A45A);font-weight:600}

.order-price{font-size:30rpx;color:var(--color-accent,#D4A45A);font-weight:600;display:block;margin-bottom:14rpx}

.card-bottom{display:flex;align-items:center;justify-content:space-between}
.order-status{font-size:24rpx;font-weight:500;padding:6rpx 18rpx;border-radius:var(--radius-round,9999rpx)}
.status-0{color:#E8A838;background:rgba(232,168,56,0.12)}
.status-1{color:#7D9A6A;background:rgba(125,154,106,0.12)}
.status-2{color:#D4A45A;background:rgba(212,164,90,0.12)}
.status-3{color:#3E2723;background:rgba(62,39,35,0.10)}

.order-time{font-size:22rpx;color:var(--color-text-muted,#9B8E85)}

.order-actions{display:flex;justify-content:flex-end;align-items:center;margin-top:18rpx;flex-wrap:wrap;gap:12rpx}
.btn-pay{background:linear-gradient(135deg,#7D9A6A,#9CB87E);color:#fff;font-size:24rpx;padding:12rpx 32rpx;border-radius:9999rpx;line-height:1;display:inline-block;font-weight:600;letter-spacing:2rpx;box-shadow:0 2rpx 6rpx rgba(125,154,106,0.30);margin-right:auto}
.btn-pay:active{opacity:0.85;transform:scale(0.96)}
.btn-cancel{background:#C4493D;color:#fff;font-size:24rpx;padding:12rpx 32rpx;border-radius:9999rpx;line-height:1;display:inline-block;font-weight:500;letter-spacing:2rpx;box-shadow:0 2rpx 6rpx rgba(196,73,61,0.25)}
.btn-cancel:active{background:#A33B33;transform:scale(0.96)}
.btn-delete{background:#9B8E85;color:#fff;font-size:24rpx;padding:12rpx 32rpx;border-radius:9999rpx;line-height:1;display:inline-block;font-weight:500;letter-spacing:2rpx;box-shadow:0 2rpx 6rpx rgba(155,142,133,0.25);margin-left:16rpx}
.btn-delete:active{background:#7B6F65;transform:scale(0.96)}

.status-4{color:#9B8E85;background:rgba(155,142,133,0.18)}

.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:160rpx 40rpx}
.empty-icon{width:120rpx;height:120rpx;margin-bottom:28rpx;opacity:0.35}
.empty-text{font-size:28rpx;color:var(--color-text-muted,#9B8E85)}
.empty-sub{font-size:24rpx;color:var(--color-text-muted,#9B8E85);margin-top:10rpx;opacity:0.6}
