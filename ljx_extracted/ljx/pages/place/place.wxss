/* pages/place/place.wxss */
/* 搜索框 */
.search-bar{
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}
.search-icon{
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  margin-left: 20rpx;
  z-index: 10;
}
.search-input{
  flex: 1;
  background: #f5f5f5;
  height: 70rpx;
  border-radius: 35rpx;
  padding: 0 80rpx;
  font-size: 28rpx;
  border: 2rpx solid #8B4513;
}
/* 导航栏 */
.category-scroll{
  white-space: nowrap;
  background: #fff;
}
.category-list{
  display: flex;
  justify-content: center;
  padding: 20rpx;
}
.category-item{
  padding: 15rpx 40rpx;
  margin-right: 20rpx;
  font-size: 40rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}
.category-item.active{
  color: #8B4513;
  border-bottom-color: #8B4513;
  font-weight: bold;
}
/* 主题内容 */
.content-card{
  margin: 20rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  border: 2rpx solid gray;
}
.card-img{
  width: 100%;
  height: 300rpx;
  padding-top: 20rpx;
}
.card-body{
  padding: 25rpx;
}

.location{
  font-size: 26rpx;
  color: #999;
}

.user-info{
  display: flex;
  align-items: center;
  padding: 20rpx;
}
.user-detail{
  display: flex;
  flex-direction: column;
}
.avatar{
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}
.username{
  margin-left: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.personal{
  margin-left: 20rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}
/* 操作栏 */
.actions{
  display: flex;
  justify-content: flex-start;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.action-item{
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 30rpx;
  margin-right: 60rpx;
}
.action-icon{
  width: 40rpx;
  height: 40rpx;
}
.action-text{
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}