<!--pages/login/login.wxml-->
<!--登录页 6/29 新建: 手机号或邮箱 + 密码, 实时校验-->

<view class="page">

  <!-- 顶部装饰 -->
  <view class="header">
    <view class="logo-circle">
      <text class="logo-text">榫</text>
    </view>
    <text class="title">欢迎回来</text>
    <text class="subtitle">登录榫卯文化传承社区</text>
  </view>

  <!-- 表单 -->
  <view class="form">

    <!-- 账号 (手机号或邮箱) -->
    <view class="field {{accountError ? 'error' : (accountValid ? 'valid' : '')}}">
      <text class="field-label">账号</text>
      <input
        class="field-input"
        placeholder="手机号或邮箱"
        placeholder-class="placeholder"
        value="{{account}}"
        bindinput="onAccountInput"
      />
      <text class="field-icon" wx:if="{{accountValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{accountError}}">{{accountError}}</text>
    <text class="field-tip hint-tip" wx:if="{{!accountError && !accountValid && account}}">
      请输入正确的手机号或邮箱
    </text>

    <!-- 密码 -->
    <view class="field {{passwordError ? 'error' : (passwordValid ? 'valid' : '')}}">
      <text class="field-label">密码</text>
      <input
        class="field-input"
        password="{{true}}"
        placeholder="请输入密码 (6-20 位)"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <text class="field-icon" wx:if="{{passwordValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{passwordError}}">{{passwordError}}</text>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{canSubmit ? 'active' : ''}}"
      disabled="{{!canSubmit || submitting}}"
      bindtap="onSubmit"
    >
      {{submitting ? '登录中...' : '登录'}}
    </button>

    <!-- 去注册 -->
    <view class="bottom-link">
      <text>还没有账号？</text>
      <text class="link" bindtap="goToRegister">去注册</text>
    </view>

  </view>
</view>
