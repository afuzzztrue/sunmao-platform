<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="ornament">
    <view class="ornament-line"></view>
    <view class="ornament-diamond"></view>
    <view class="ornament-line"></view>
  </view>

  <view class="title">欢迎登录</view>
  <view class="subtitle">登录后体验更多功能</view>

  <view class="form">
    <view class="input-wrapper">
      <input class="input" placeholder="请输入账号" bindinput="inputAccount" value="{{account}}" />
    </view>
    <view class="input-wrapper">
      <input class="input" placeholder="请输入密码" password bindinput="inputPassword" value="{{password}}" />
    </view>
  </view>

  <button class="btn-login {{loading ? 'disabled' : ''}}" bindtap="doLogin" disabled="{{loading}}">
    {{loading ? '登录中...' : '登录'}}
  </button>

  <view class="footer">
    <text class="text">没有账号？</text>
    <text class="link" bindtap="goToRegister">立即注册</text>
  </view>

  <view class="test-tip">
    <text class="tip-title">测试账号</text>
    <text class="tip-content">账号：test  密码：123456</text>
  </view>
</view>
