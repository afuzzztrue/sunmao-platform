page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:40rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A}
.upload-btn{padding:8rpx 20rpx;font-size:26rpx;color:#D4A45A;border:1rpx solid #D4A45A;border-radius:9999rpx;font-weight:500}

.stats-bar{display:flex;gap:16rpx;padding:24rpx;background:#FFFFFF;border-bottom:1rpx solid rgba(62,39,35,0.05)}
.stat-pill{flex:1;display:flex;flex-direction:column;align-items:center;background:rgba(212,164,90,0.08);border-radius:16rpx;padding:16rpx 0;font-size:24rpx;color:#9B8E85}
.stat-pill-num{font-size:36rpx;font-weight:700;color:#3E2723;display:block;margin-bottom:4rpx}

.works-grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx;padding:20rpx 24rpx 0}
.work-card{background:#FFFFFF;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);transition:transform 0.2s}
.work-card:active{transform:scale(0.98)}
.work-img{width:100%;aspect-ratio:1/1;background:#F5F0E8;display:block}
.work-info{padding:16rpx}
.work-title{font-size:26rpx;font-weight:600;color:#1A1A1A;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.work-stats{font-size:22rpx;color:#9B8E85;display:block;margin-top:8rpx}

.empty{display:flex;flex-direction:column;align-items:center;padding:160rpx 40rpx}
.empty-icon{font-size:96rpx;opacity:0.40;line-height:1;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#9B8E85;font-weight:500}
.empty-sub{font-size:24rpx;color:#9B8E85;margin-top:10rpx;opacity:0.6;text-align:center}
