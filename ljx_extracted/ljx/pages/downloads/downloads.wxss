page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:120rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A}
.manage-btn{font-size:26rpx;color:#D4A45A;font-weight:500;padding:8rpx 12rpx}

.summary-bar{background:#FFFFFF;padding:20rpx 24rpx;border-bottom:1rpx solid rgba(62,39,35,0.05)}
.summary-text{font-size:24rpx;color:#9B8E85}
.summary-num{color:#3E2723;font-weight:700}

.course-list{padding:20rpx 24rpx 0}
.course-card{display:flex;background:#FFFFFF;border-radius:20rpx;padding:20rpx;margin-bottom:16rpx;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);position:relative}
.course-img{width:180rpx;height:180rpx;border-radius:12rpx;background:#F5F0E8;flex-shrink:0}
.course-info{flex:1;margin-left:20rpx;display:flex;flex-direction:column;justify-content:space-between;min-width:0}
.course-title{font-size:28rpx;font-weight:600;color:#1A1A1A;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.course-author{font-size:22rpx;color:#9B8E85;display:block;margin-top:6rpx}
.progress-wrap{display:flex;align-items:center;margin-top:8rpx}
.progress-bar{flex:1;height:10rpx;background:rgba(212,164,90,0.15);border-radius:9999rpx;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,#D4A45A,#E8B86E);border-radius:9999rpx}
.progress-text{font-size:20rpx;color:#9B8E85;margin-left:12rpx;flex-shrink:0}
.course-actions{display:flex;gap:12rpx;margin-top:12rpx}
.course-btn{padding:10rpx 20rpx;font-size:24rpx;border-radius:9999rpx;font-weight:500}
.btn-primary{background:#D4A45A;color:#FFFFFF}
.btn-ghost{background:transparent;color:#D4A45A;border:1rpx solid #D4A45A}
.course-checkbox{position:absolute;top:20rpx;right:20rpx;width:40rpx;height:40rpx;border-radius:50%;border:2rpx solid #9B8E85;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:transparent;background:#FFFFFF}
.course-checkbox.checked{background:#D4A45A;border-color:#D4A45A;color:#FFFFFF}

.manage-bar{position:fixed;left:0;right:0;bottom:0;background:#FFFFFF;padding:20rpx 24rpx;box-shadow:0 -4rpx 12rpx rgba(62,39,35,0.08);display:flex;align-items:center;justify-content:space-between;z-index:20}
.manage-info{font-size:28rpx;color:#1A1A1A}
.manage-info-num{color:#D4A45A;font-weight:700;margin:0 4rpx}
.manage-btn-bar{padding:14rpx 40rpx;background:#C4493D;color:#FFFFFF;border-radius:9999rpx;font-size:28rpx;font-weight:600}

.empty{display:flex;flex-direction:column;align-items:center;padding:160rpx 40rpx}
.empty-icon{font-size:96rpx;opacity:0.40;line-height:1;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#9B8E85;font-weight:500}
.empty-sub{font-size:24rpx;color:#9B8E85;margin-top:10rpx;opacity:0.6;text-align:center}
