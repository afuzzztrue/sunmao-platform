page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:60rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A;margin-right:-60rpx}

.user-card{display:flex;align-items:center;background:#FFFFFF;margin:24rpx 24rpx 0;padding:32rpx;border-radius:20rpx;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.user-avatar{width:96rpx;height:96rpx;border-radius:50%;background:#F5F0E8;flex-shrink:0}
.user-info{flex:1;margin-left:20rpx;display:flex;flex-direction:column;min-width:0}
.user-name{font-size:32rpx;font-weight:600;color:#1A1A1A;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.user-id{font-size:22rpx;color:#9B8E85;display:block;margin-top:6rpx}
.user-edit{font-size:26rpx;color:#D4A45A;font-weight:500}

.section-title{font-size:24rpx;color:#9B8E85;letter-spacing:2rpx;padding:32rpx 32rpx 12rpx}
.setting-list{background:#FFFFFF;margin:0 24rpx;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.setting-item{display:flex;align-items:center;justify-content:space-between;padding:28rpx 32rpx;border-bottom:1rpx solid rgba(62,39,35,0.05);transition:background 0.2s}
.setting-item:last-child{border-bottom:none}
.setting-item:active{background:rgba(212,164,90,0.06)}
.setting-text{font-size:28rpx;color:#1A1A1A}
.setting-value{font-size:26rpx;color:#9B8E85}
.setting-arrow{font-size:32rpx;color:#9B8E85;font-weight:300}

.logout-section{padding:60rpx 24rpx 0}
.logout-btn{background:#C4493D;color:#FFFFFF;text-align:center;padding:28rpx;border-radius:9999rpx;font-size:30rpx;font-weight:600;letter-spacing:4rpx;box-shadow:0 4rpx 12rpx rgba(196,73,61,0.25)}
