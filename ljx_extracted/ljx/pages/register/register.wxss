/* pages/register/register.wxss */
.register-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 56rpx 80rpx;
  background: #F5F0E8;
  min-height: 100vh;
  box-sizing: border-box;
}

.ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}

.ornament-line {
  width: 72rpx;
  height: 2rpx;
  background: #D4A45A;
  opacity: 0.45;
}

.ornament-diamond {
  width: 18rpx;
  height: 18rpx;
  background: #D4A45A;
  transform: rotate(45deg);
  opacity: 0.55;
  margin: 0 20rpx;
  border-radius: 2rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #3E2723;
  text-align: center;
  line-height: 1.3;
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6B5E55;
  text-align: center;
  margin-bottom: 64rpx;
}

.form {
  width: 100%;
  margin-bottom: 32rpx;
}

.input-wrapper {
  margin-bottom: 24rpx;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(62,39,35,0.08);
  box-sizing: border-box;
  display: flex;
  align-items: center;
  padding: 0 36rpx;
}

.input-wrapper-focus {
  border-color: #D4A45A;
  box-shadow: 0 4rpx 16rpx rgba(62,39,35,0.12);
}

.input {
  flex: 1;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  font-size: 30rpx;
  color: #1A1A1A;
  box-shadow: none;
  box-sizing: border-box;
}

.input:focus {
  border: none;
  box-shadow: none;
}

.btn-register {
  width: 100%;
  background-image: linear-gradient(135deg, #3E2723, #5D4037);
  color: #FFFFFF;
  border-radius: 9999rpx;
  padding: 30rpx;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 44rpx;
  border: none;
  box-shadow: 0 8rpx 28rpx rgba(62,39,35,0.28);
  letter-spacing: 4rpx;
}

.btn-register.disabled {
  background-image: linear-gradient(135deg, #BDBDBD, #9E9E9E);
  box-shadow: none;
  color: #FFFFFF;
}

.btn-register::after {
  border: none;
}

.footer {
  display: flex;
  justify-content: center;
  align-items: center;
}

.text {
  font-size: 28rpx;
  color: #6B5E55;
}

.link {
  font-size: 28rpx;
  color: #D4A45A;
  margin-left: 8rpx;
  font-weight: 600;
}
