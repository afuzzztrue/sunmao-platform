/* pages/register/register.wxss */
/* 注册页样式 6/29 新建 */

.page {
  background: #F5F0E8;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 顶部装饰 ========== */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #3E2723;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 56rpx;
  color: #F5F0E8;
  font-weight: bold;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3E2723;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* ========== 表单 ========== */
.form {
  padding: 20rpx 48rpx;
}

.field {
  display: flex;
  align-items: center;
  background: #FFF;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.field.error {
  border-color: #E53935;
}

.field.valid {
  border-color: #43A047;
}

.field-label {
  font-size: 28rpx;
  color: #6B5B4F;
  width: 140rpx;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #333;
}

.placeholder {
  color: #CCC;
  font-size: 28rpx;
}

.field-icon {
  font-size: 36rpx;
  color: #43A047;
  margin-left: 12rpx;
}

/* 7/1 新增: 密码可见性切换图标 */
.eye-icon {
  width: 44rpx;
  height: 44rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.field-tip {
  display: block;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  padding-left: 28rpx;
}

.error-tip {
  color: #E53935;
}

/* ========== 提交按钮 ========== */
.submit-btn {
  margin-top: 40rpx;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #D5C8B8;
  color: #999;
  text-align: center;
  border: none;
}

.submit-btn.active {
  background: #3E2723;
  color: #FFF;
}

.submit-btn[disabled] {
  opacity: 0.7;
}

/* ========== 底部链接 ========== */
.bottom-link {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

.link {
  color: #3E2723;
  font-weight: 600;
  margin-left: 8rpx;
}
