<!--pages/register/register.wxml-->
<view class="register-container">
  <view class="ornament">
    <view class="ornament-line"></view>
    <view class="ornament-diamond"></view>
    <view class="ornament-line"></view>
  </view>

  <view class="title">注册账号</view>
  <view class="subtitle">加入我们，一起传承非遗文化</view>

  <view class="form">
    <view class="input-wrapper">
      <input class="input" placeholder="请输入账号（至少4位）" bindinput="inputAccount" value="{{account}}" />
    </view>
    <view class="input-wrapper">
      <input class="input" placeholder="请输入昵称（可选）" bindinput="inputNickname" value="{{nickname}}" />
    </view>
    <view class="input-wrapper">
      <input class="input" placeholder="请设置密码（至少6位）" password bindinput="inputPassword" value="{{password}}" />
    </view>
    <view class="input-wrapper">
      <input class="input" placeholder="请确认密码" password bindinput="inputConfirmPassword" value="{{confirmPassword}}" />
    </view>
  </view>

  <button class="btn-register {{loading ? 'disabled' : ''}}" bindtap="doRegister" disabled="{{loading}}">
    {{loading ? '注册中...' : '注册'}}
  </button>

  <view class="footer">
    <text class="text">已有账号？</text>
    <text class="link" bindtap="goToLogin">立即登录</text>
  </view>
</view>
