<!--pages/register/register.wxml-->
<!--注册页 6/29 新建: 手机号/邮箱/昵称/密码/确认密码, 实时校验-->

<view class="page">

  <!-- 顶部装饰 -->
  <view class="header">
    <view class="logo-circle">
      <text class="logo-text">榫</text>
    </view>
    <text class="title">创建账号</text>
    <text class="subtitle">加入榫卯文化传承社区</text>
  </view>

  <!-- 表单 -->
  <view class="form">

    <!-- 1 手机号 -->
    <view class="field {{phoneError ? 'error' : (phoneValid ? 'valid' : '')}}">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
      <text class="field-icon" wx:if="{{phoneValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{phoneError}}">{{phoneError}}</text>

    <!-- 2 邮箱 -->
    <view class="field {{emailError ? 'error' : (emailValid ? 'valid' : '')}}">
      <text class="field-label">邮箱</text>
      <input
        class="field-input"
        placeholder="请输入邮箱地址"
        placeholder-class="placeholder"
        value="{{email}}"
        bindinput="onEmailInput"
      />
      <text class="field-icon" wx:if="{{emailValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{emailError}}">{{emailError}}</text>

    <!-- 3 昵称 -->
    <view class="field {{nicknameError ? 'error' : (nicknameValid ? 'valid' : '')}}">
      <text class="field-label">昵称</text>
      <input
        class="field-input"
        placeholder="请输入昵称 (2-20 字符)"
        placeholder-class="placeholder"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
      <text class="field-icon" wx:if="{{nicknameValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{nicknameError}}">{{nicknameError}}</text>

    <!-- 4 密码 -->
    <view class="field {{passwordError ? 'error' : (passwordValid ? 'valid' : '')}}">
      <text class="field-label">密码</text>
      <input
        class="field-input"
        password="{{!passwordVisible}}"
        placeholder="请输入密码 (6-20 位)"
        placeholder-class="placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
      <!-- 7/1 新增: 密码可见性切换图标 -->
      <image
        class="eye-icon"
        src="{{passwordVisible ? '../images/眼睛开.png' : '../images/眼睛-闭.png'}}"
        mode="aspectFit"
        bindtap="onTogglePasswordVisible"
      />
      <text class="field-icon" wx:if="{{passwordValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{passwordError}}">{{passwordError}}</text>

    <!-- 5 确认密码 -->
    <view class="field {{confirmPasswordError ? 'error' : (confirmPasswordValid ? 'valid' : '')}}">
      <text class="field-label">确认密码</text>
      <input
        class="field-input"
        password="{{!confirmPasswordVisible}}"
        placeholder="请再次输入密码"
        placeholder-class="placeholder"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
      <!-- 7/1 新增: 确认密码可见性切换图标 -->
      <image
        class="eye-icon"
        src="{{confirmPasswordVisible ? '../images/眼睛开.png' : '../images/眼睛-闭.png'}}"
        mode="aspectFit"
        bindtap="onToggleConfirmPasswordVisible"
      />
      <text class="field-icon" wx:if="{{confirmPasswordValid}}">✓</text>
    </view>
    <text class="field-tip error-tip" wx:if="{{confirmPasswordError}}">{{confirmPasswordError}}</text>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{canSubmit ? 'active' : ''}}"
      disabled="{{!canSubmit || submitting}}"
      bindtap="onSubmit"
    >
      {{submitting ? '注册中...' : '注册'}}
    </button>

    <!-- 去登录 -->
    <view class="bottom-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goToLogin">去登录</text>
    </view>

  </view>
</view>
