<view class="subpage">
  <view class="subpage-header">
    <view class="back-btn" bindtap="goBack" hover-class="btn-hover">‹</view>
    <text class="subpage-title">我的收藏</text>
  </view>

  <view class="subpage-stats">
    <text class="stats-text">共 {{list.length}} 个</text>
  </view>

  <view class="likes-grid" wx:if="{{list.length}}">
    <view class="like-card"
          wx:for="{{list}}"
          wx:key="id"
          bindtap="onTapCard"
          data-id="{{item.id}}"
          data-type="{{item.type}}"
          data-targetid="{{item.targetId}}"
          hover-class="card-hover">
      <image class="like-img" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="type-badge type-{{item.type}}">{{item.typeName}}</view>
      <view class="like-mask">
        <text class="like-title">{{item.title}}</text>
        <view class="like-meta">
          <text class="like-time">{{item.time}}</text>
        </view>
        <view class="like-actions">
          <view class="like-action" catchtap="onUncollect" data-id="{{item.id}}" data-type="{{item.type}}" data-targetid="{{item.targetId}}">
            <text>★ 取消</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-icon">★</text>
    <text class="empty-text">还没有收藏</text>
    <text class="empty-sub">去「分类」或「商城」看看，喜欢的就收藏起来</text>
  </view>
</view>
