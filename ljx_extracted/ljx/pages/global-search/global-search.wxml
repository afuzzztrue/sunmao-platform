<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索榫卯、课程、商品、作品..."
        placeholder-class="search-placeholder-class"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
        focus="{{true}}"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearKeyword">✕</view>
    </view>
    <text class="search-cancel" bindtap="onCancel">取消</text>
  </view>

  <view class="search-section" wx:if="{{!keyword}}">
    <view class="section-title-row">
      <text class="section-title-text">历史搜索</text>
      <text class="section-action" bindtap="clearHistory">🗑 清空</text>
    </view>
    <view class="tag-list">
      <view class="tag" wx:for="{{history}}" wx:key="*this" bindtap="onTapTag" data-text="{{item}}">{{item}}</view>
      <view class="tag tag-empty" wx:if="{{!history.length}}">暂无搜索记录</view>
    </view>
  </view>

  <view class="search-section" wx:if="{{!keyword}}">
    <view class="section-title-row"><text class="section-title-text">热门搜索</text></view>
    <view class="tag-list">
      <view class="tag hot" wx:for="{{hotList}}" wx:key="*this" bindtap="onTapTag" data-text="{{item}}">
        <text class="hot-rank">{{idx+1 < 10 ? '0'+(idx+1) : idx+1}}</text>
        {{item}}
      </view>
    </view>
  </view>

  <view class="result-tip" wx:if="{{keyword}}">
    找到 <text class="result-count">{{resultList.length}}</text> 个匹配结果
  </view>

  <view class="result-list" wx:if="{{keyword && resultList.length}}">
    <view class="result-card" wx:for="{{resultList}}" wx:key="id" bindtap="onTapResult" data-type="{{item.type}}" data-id="{{item.id}}">
      <view class="result-type">{{typeMap[item.type]}}</view>
      <image class="result-img" src="{{item.image}}" mode="aspectFill" />
      <view class="result-info">
        <text class="result-title">{{item.title}}</text>
        <text class="result-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{keyword && !resultList.length}}">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">未找到相关内容</text>
    <text class="empty-sub">试试「圈椅」「紫檀」「入门30天」等关键词</text>
  </view>
</view>
