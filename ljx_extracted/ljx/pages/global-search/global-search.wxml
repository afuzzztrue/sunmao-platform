<!--pages/global-search/global-search.wxml-->
<!--全局搜索页 6/29 新建-->

<view class="page">

  <!-- 顶部搜索栏 -->
  <view class="search-header">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索榫卯结构 / 家具 / 教程"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        confirm-type="search"
        bindinput="onInput"
        bindconfirm="onSearch"
      />
      <text class="search-btn-text" bindtap="onSearch">搜索</text>
    </view>
  </view>

  <!-- 热门搜索 (未搜索时显示) -->
  <view class="hot-section" wx:if="{{!searched}}">
    <text class="hot-label">热门搜索</text>
    <view class="hot-list">
      <text class="hot-tag" wx:for="{{hotKeywords}}" wx:key="*this"
            data-kw="{{item}}" bindtap="onTapHotKeyword">{{item}}</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="results-section" wx:if="{{searched}}">
    <view class="results-count" wx:if="{{results.length > 0}}">
      <text>找到 {{results.length}} 条结果</text>
    </view>

    <view class="result-card" wx:for="{{results}}" wx:key="index"
          data-type="{{item.type}}" data-id="{{item.typeId}}"
          bindtap="onTapResult" hover-class="card-hover">
      <image class="result-img" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}" />
      <view class="result-img-placeholder" wx:else>
        <text class="placeholder-text">无图</text>
      </view>
      <view class="result-info">
        <view class="result-title-row">
          <text class="result-type type-{{item.type}}">{{item.typeName}}</text>
          <text class="result-title">{{item.title}}</text>
        </view>
        <text class="result-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
      </view>
    </view>

    <!-- 空结果 -->
    <view class="empty-state" wx:if="{{!loading && results.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到相关内容</text>
      <text class="empty-sub">试试其他关键词</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">搜索中...</text>
  </view>

</view>
