page{background:#F5F0E8;min-height:100vh}
.container{padding:0;background:#F5F0E8;min-height:100vh}

.search-bar{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);position:sticky;top:0;z-index:10}
.search-input-wrap{flex:1;display:flex;align-items:center;background:#F5F0E8;border-radius:9999rpx;padding:14rpx 24rpx;border:2rpx solid transparent;transition:all 0.2s;min-width:0}
.search-input-wrap:focus-within{border-color:#D4A45A;background:#FFFFFF}
.search-icon{font-size:28rpx;margin-right:12rpx;line-height:1;flex-shrink:0}
.search-input{flex:1;font-size:28rpx;color:#1A1A1A;height:44rpx;line-height:44rpx;background:transparent;min-width:0}
.search-placeholder-class{color:#9B8E85;font-size:28rpx}
.search-clear{width:36rpx;height:36rpx;background:rgba(155,142,133,0.20);color:#FFFFFF;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22rpx;margin-left:12rpx;flex-shrink:0}
.search-cancel{font-size:28rpx;color:#1A1A1A;margin-left:20rpx;flex-shrink:0;font-weight:500}

.search-section{padding:24rpx 24rpx 0}
.section-title-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}
.section-title-text{font-size:26rpx;color:#3E2723;font-weight:600;letter-spacing:2rpx}
.section-action{font-size:24rpx;color:#9B8E85}

.tag-list{display:flex;flex-wrap:wrap;gap:16rpx}
.tag{padding:14rpx 28rpx;font-size:26rpx;color:#5C5048;background:#FFFFFF;border-radius:9999rpx;box-shadow:0 2rpx 6rpx rgba(62,39,35,0.06);border:1rpx solid rgba(212,164,90,0.2);transition:all 0.2s}
.tag:active{background:rgba(212,164,90,0.10);transform:scale(0.97)}
.tag.hot{display:flex;align-items:center;gap:8rpx}
.hot-rank{display:inline-flex;align-items:center;justify-content:center;min-width:32rpx;height:32rpx;padding:0 8rpx;font-size:22rpx;font-weight:700;color:#FFFFFF;background:#D4A45A;border-radius:8rpx}
.tag-empty{color:#9B8E85;opacity:0.6;font-size:24rpx}

.result-tip{padding:20rpx 32rpx 8rpx;font-size:24rpx;color:#9B8E85}
.result-count{color:#D4A45A;font-weight:700;margin:0 4rpx}

.result-list{padding:16rpx 24rpx 40rpx}
.result-card{position:relative;background:#FFFFFF;border-radius:16rpx;padding:20rpx;margin-bottom:16rpx;display:flex;align-items:center;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);transition:transform 0.2s}
.result-card:active{transform:scale(0.99);background:#FBF7F1}
.result-type{position:absolute;top:14rpx;right:14rpx;font-size:20rpx;color:#D4A45A;background:rgba(212,164,90,0.10);padding:4rpx 12rpx;border-radius:8rpx;font-weight:500}
.result-img{width:120rpx;height:120rpx;border-radius:12rpx;background:#F5F0E8;flex-shrink:0}
.result-info{flex:1;margin-left:20rpx;display:flex;flex-direction:column;justify-content:center;min-width:0}
.result-title{font-size:28rpx;font-weight:600;color:#1A1A1A;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.result-desc{font-size:24rpx;color:#9B8E85;display:block;margin-top:6rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.empty{display:flex;flex-direction:column;align-items:center;padding:120rpx 40rpx}
.empty-icon{font-size:80rpx;opacity:0.40;line-height:1;margin-bottom:24rpx}
.empty-text{font-size:28rpx;color:#9B8E85;font-weight:500}
.empty-sub{font-size:24rpx;color:#9B8E85;margin-top:10rpx;opacity:0.6;text-align:center}
