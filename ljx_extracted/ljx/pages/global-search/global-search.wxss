/* pages/global-search/global-search.wxss */
/* 全局搜索页样式 6/29 新建 */

.page {
  background: #F5F0E8;
  min-height: 100vh;
}

/* ========== 顶部搜索栏 ========== */
.search-header {
  background: #3E2723;
  padding: 20rpx 24rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 40rpx;
  height: 72rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

.search-btn-text {
  font-size: 28rpx;
  color: #3E2723;
  font-weight: 600;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ========== 热门搜索 ========== */
.hot-section {
  padding: 40rpx 30rpx;
}

.hot-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 24rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.hot-tag {
  padding: 14rpx 32rpx;
  background: #FFF;
  border: 1rpx solid #E0D5C5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #6B5B4F;
}

.hot-tag:active {
  background: #F0E8DC;
}

/* ========== 搜索结果 ========== */
.results-section {
  padding: 20rpx 24rpx;
}

.results-count {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.result-card {
  display: flex;
  background: #FFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #E8E0D0;
}

.card-hover {
  opacity: 0.85;
}

.result-img {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: #F0E8DC;
}

.result-img-placeholder {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  background: #F0E8DC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 24rpx;
  color: #CCC;
}

.result-info {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.result-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.result-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  color: #FFF;
  flex-shrink: 0;
}

.type-1 { background: #4A90D9; }
.type-2 { background: #7BAA4A; }
.type-3 { background: #E5A04A; }
.type-4 { background: #D94A4A; }
.type-5 { background: #9B6BD9; }

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #CCC;
}

/* ========== 加载中 ========== */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}
