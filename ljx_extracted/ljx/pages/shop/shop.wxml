<view class="shop-container">
  <view class="sticky-header">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索榫卯好物..." value="{{keyword}}" bindinput="onSearchInput" />
    </view>

    <view wx:if="{{keyword}}" class="search-tag">
      <text class="search-tag-text">搜索: {{keyword}}</text>
      <view class="search-tag-clear" bindtap="clearKeyword">✕</view>
    </view>

    <scroll-view scroll-x class="category-scroll">
      <view class="cat-scroll-inner">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="cat-item {{currentCat == item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="switchCat"
        >{{item.name}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="product-grid">
    <view
      class="product-card"
      wx:for="{{productList}}"
      wx:key="productId"
      bindtap="goDetail"
      data-id="{{item.productId}}"
    >
      <image class="product-img" src="{{item.coverImage}}" mode="aspectFill" binderror="onImgError" data-index="{{index}}" />
      <view class="product-info">
        <text class="product-name">{{item.productName}}</text>
        <text class="product-price">¥{{item.price}}</text>
      </view>
    </view>
    <view wx:if="{{!productList.length}}" class="empty">
      <text class="empty-icon">🪵</text>
      <text>暂无商品，匠人正在赶制中...</text>
    </view>
  </view>

  <!-- 自定义 tabBar (抖音式, 中间 + 号) -->
  <custom-tab-bar />

</view>
