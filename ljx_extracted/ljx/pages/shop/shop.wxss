page {
  --color-primary: #3E2723;
  --color-accent: #D4A45A;
  --color-bg: #F5F0E8;
  --color-bg-card: #FFFFFF;
  --color-text: #1A1A1A;
  --color-text-secondary: #6B5E55;
  --color-text-muted: #9B8E85;
  --color-border: rgba(62, 39, 35, 0.08);
  --color-highlight: #C4493D;
  --color-success: #7D9A6A;
  --shadow-sm: 0 2rpx 8rpx rgba(62, 39, 35, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(62, 39, 35, 0.10);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-round: 9999rpx;
  background-color: var(--color-bg);
}

.shop-container {
  padding: 0 0 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 固定头部：搜索框 + 搜索词提示 + tab 滚动条 始终贴在顶部 */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--color-bg);
  padding: 24rpx 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(62, 39, 35, 0.06);
}

.search-bar {
  padding: 0 0 20rpx;
}

.search-input {
  display: block;
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
  padding: 20rpx 36rpx;
  font-size: 28rpx;
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
  width: 100%;
}

.search-input::placeholder {
  color: var(--color-text-muted);
}

.search-tag {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(212, 164, 90, 0.12);
  border: 1rpx solid rgba(212, 164, 90, 0.3);
  border-radius: var(--radius-sm);
  padding: 14rpx 22rpx;
  margin-bottom: 16rpx;
}

.search-tag-text {
  font-size: 26rpx;
  color: var(--color-accent);
  font-weight: 600;
}

.search-tag-clear {
  width: 36rpx;
  height: 36rpx;
  background: var(--color-accent);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.category-scroll {
  white-space: nowrap;
  padding: 4rpx 0 24rpx;
  display: flex;
  flex-direction: row;
}

.cat-scroll-inner {
  display: inline-flex;
  flex-direction: row;
  gap: 16rpx;
}

.cat-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 36rpx;
  border-radius: var(--radius-round);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-sm);
  transition: all 0.25s ease;
  flex-shrink: 0;
}

.cat-item.active {
  background: var(--color-accent);
  color: #fff;
  font-weight: 600;
  border-color: var(--color-accent);
  box-shadow: var(--shadow-md);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 16rpx 24rpx 40rpx;
}

.product-grid::after {
  content: '';
  width: 47%;
}

.product-card {
  width: 47%;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease;
}

.product-card:active {
  transform: scale(0.97);
}

.product-img {
  width: 100%;
  height: 340rpx;
  display: block;
  background: #F0EBE3;
}

.product-img-fallback {
  width: 100%;
  height: 340rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #EDE4D3, #E8DDCC);
}

.product-img-fallback text {
  font-size: 60rpx;
  color: var(--color-accent);
}

.product-info {
  padding: 18rpx 20rpx 22rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 28rpx;
  color: var(--color-text);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.product-price {
  font-size: 32rpx;
  color: var(--color-highlight);
  font-weight: 700;
  letter-spacing: 2rpx;
}

.product-price-symbol {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-accent);
}

.empty {
  width: 100%;
  text-align: center;
  color: var(--color-text-muted);
  padding: 120rpx 0;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.4;
}
