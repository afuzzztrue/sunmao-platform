<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="输入商品名关键字搜索订单"
        placeholder-class="search-placeholder-class"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
        focus="{{true}}"
      />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="clearKeyword">✕</view>
    </view>
    <text class="search-cancel" bindtap="onCancel">取消</text>
  </view>

  <view class="result-tip" wx:if="{{keyword}}">
    找到 <text class="result-count">{{resultList.length}}</text> 个匹配订单
  </view>

  <view class="order-list" wx:if="{{resultList.length}}">
    <view
      class="order-card"
      wx:for="{{resultList}}"
      wx:key="orderId"
      bindtap="goToOrder"
      data-id="{{item.orderId}}"
      hover-class="card-hover"
      hover-stay-time="100"
    >
      <view class="card-top">
        <text class="order-name">{{item.productName}}</text>
        <view class="qty-badge">
          <text>×{{item.quantity}}</text>
        </view>
      </view>
      <text class="order-price">¥{{item.totalPrice}}</text>
      <view class="card-bottom">
        <text class="order-status status-{{item.status}}">{{statusMap[item.status] || '待支付'}}</text>
        <text class="order-time">{{item.createTime}}</text>
      </view>
      <view class="tap-hint">
        <text>点击定位到订单 ›</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">{{keyword ? '🔍' : '🧾'}}</text>
    <text class="empty-text">{{keyword ? '未找到匹配订单' : '请输入商品名关键字'}}</text>
    <text class="empty-sub" wx:if="{{keyword}}">试试更短的关键词或检查拼写</text>
    <text class="empty-sub" wx:else>仅搜索「我的订单」商品名</text>
  </view>
</view>
