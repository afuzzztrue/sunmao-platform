page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:40rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A;margin-right:-60rpx}

.filter-tabs{display:flex;gap:16rpx;padding:24rpx;background:#FFFFFF;border-bottom:1rpx solid rgba(62,39,35,0.05)}
.filter-tab{padding:10rpx 28rpx;font-size:26rpx;color:#9B8E85;background:rgba(212,164,90,0.06);border-radius:9999rpx;transition:all 0.2s}
.filter-tab.active{color:#FFFFFF;background:#D4A45A;font-weight:600;box-shadow:0 2rpx 6rpx rgba(212,164,90,0.3)}

.footprint-list{padding:20rpx 24rpx 0}
.day-group{margin-bottom:24rpx}
.day-title{font-size:24rpx;color:#9B8E85;letter-spacing:2rpx;display:block;margin-bottom:16rpx;padding-left:8rpx}

.footprint-card{display:flex;background:#FFFFFF;border-radius:20rpx;padding:20rpx;margin-bottom:16rpx;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);transition:transform 0.2s}
.footprint-card:active{transform:scale(0.98);background:#FBF7F1}
.fp-img{width:160rpx;height:160rpx;border-radius:12rpx;background:#F5F0E8;flex-shrink:0}
.fp-info{flex:1;margin-left:20rpx;display:flex;flex-direction:column;justify-content:space-between;min-width:0}
.fp-name{font-size:28rpx;font-weight:600;color:#1A1A1A;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.fp-price{font-size:30rpx;color:#D4A45A;font-weight:700;display:block;margin-top:8rpx}
.fp-time{font-size:22rpx;color:#9B8E85;display:block}

.empty{display:flex;flex-direction:column;align-items:center;padding:160rpx 40rpx}
.empty-icon{font-size:96rpx;opacity:0.40;line-height:1;margin-bottom:24rpx}
.empty-text{font-size:30rpx;color:#9B8E85;font-weight:500}
.empty-sub{font-size:24rpx;color:#9B8E85;margin-top:10rpx;opacity:0.6;text-align:center}
