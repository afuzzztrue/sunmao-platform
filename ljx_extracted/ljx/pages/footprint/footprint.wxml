<view class="subpage">
  <view class="subpage-header">
    <view class="back-btn" bindtap="goBack" hover-class="btn-hover">‹</view>
    <text class="subpage-title">我的足迹</text>
  </view>

  <view class="subpage-stats">
    <text class="stats-text">共 {{list.length}} 条浏览记录</text>
  </view>

  <view class="footprint-list" wx:if="{{list.length}}">
    <view class="day-group" wx:for="{{dayGroups}}" wx:for-item="day" wx:key="day">
      <text class="day-title">{{day.day}}</text>
      <view class="footprint-card" wx:for="{{day.items}}" wx:for-item="o" wx:key="id"
            bindtap="onTapCard"
            data-id="{{o.targetId}}"
            data-type="{{o.targetType}}"
            hover-class="card-hover">
        <image class="fp-img" src="{{o.coverImage}}" mode="aspectFill" />
        <view class="fp-info">
          <text class="fp-name">{{o.title}}</text>
          <view class="fp-type-badge type-{{o.targetType}}">{{o.typeName}}</view>
          <text class="fp-time">{{o.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-icon">🦶</text>
    <text class="empty-text">还没有足迹</text>
    <text class="empty-sub">浏览过的文章/帖子/课程会出现在这里</text>
  </view>
</view>
