page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:40rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A;margin-right:-60rpx}

.filter-tabs{display:flex;gap:16rpx;padding:24rpx;background:#FFFFFF;border-bottom:1rpx solid rgba(62,39,35,0.05)}
.filter-tab{padding:10rpx 28rpx;font-size:26rpx;color:#9B8E85;background:rgba(212,164,90,0.06);border-radius:9999rpx}
.filter-tab.active{color:#FFFFFF;background:#D4A45A;font-weight:600}

.likes-grid{display:grid;grid-template-columns:1fr 1fr;gap:16rpx;padding:20rpx 24rpx 0}
.like-card{position:relative;aspect-ratio:1/1;border-radius:20rpx;overflow:hidden;background:#F5F0E8;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.like-img{width:100%;height:100%;display:block}
.like-mask{position:absolute;left:0;right:0;bottom:0;padding:16rpx;background:linear-gradient(to top,rgba(0,0,0,0.75),transparent)}
.like-title{font-size:24rpx;color:#FFFFFF;font-weight:600;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.like-meta{display:flex;justify-content:space-between;align-items:center;margin-top:6rpx}
.like-author{font-size:20rpx;color:rgba(255,255,255,0.75)}
.like-time{font-size:20rpx;color:rgba(255,255,255,0.55)}
.like-action{padding:6rpx 12rpx;background:rgba(255,255,255,0.18);border-radius:9999rpx;align-self:flex-start;margin-top:8rpx;display:inline-block}
.like-action text{font-size:20rpx;color:#FFFFFF}

.empty{display:flex;flex-direction:column;align-items:center;padding:160rpx 40rpx}
.empty-icon{font-size:96rpx;opacity:0.40;line-height:1;margin-bottom:24rpx;color:#9B8E85}
.empty-text{font-size:30rpx;color:#9B8E85;font-weight:500}
.empty-sub{font-size:24rpx;color:#9B8E85;margin-top:10rpx;opacity:0.6;text-align:center}
