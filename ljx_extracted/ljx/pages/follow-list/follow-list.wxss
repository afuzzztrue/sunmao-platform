/* pages/follow-list/follow-list.wxss */

.page {
  background: var(--color-bg, #F5F0E8);
  min-height: 100vh;
}

.header {
  padding: 32rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text, #1A1A1A);
  letter-spacing: 2rpx;
}

.user-list {
  padding: 0 24rpx 40rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(62, 39, 35, 0.06));
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #E5E0D8;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  font-size: 32rpx;
  color: var(--color-text, #1A1A1A);
  font-weight: 500;
}

.arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
  flex-shrink: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted, #9B8E85);
}
