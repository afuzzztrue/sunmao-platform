page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:40rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A;margin-right:-60rpx}

.hero{background:linear-gradient(135deg,#3E2723,#5D4037);margin:24rpx 24rpx 0;border-radius:24rpx;padding:48rpx 32rpx;display:flex;flex-direction:column;align-items:center;box-shadow:0 8rpx 20rpx rgba(62,39,35,0.15)}
.hero-icon{font-size:80rpx;line-height:1;margin-bottom:16rpx}
.hero-title{font-size:36rpx;color:#FFFFFF;font-weight:600;letter-spacing:2rpx}
.hero-desc{font-size:24rpx;color:rgba(255,255,255,0.65);margin-top:8rpx}
.hero-btn{margin-top:28rpx;padding:16rpx 56rpx;background:#D4A45A;color:#FFFFFF;border-radius:9999rpx;font-size:28rpx;font-weight:600;letter-spacing:2rpx;box-shadow:0 4rpx 12rpx rgba(212,164,90,0.3)}

.contact-list{background:#FFFFFF;margin:20rpx 24rpx 0;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.contact-item{display:flex;align-items:center;padding:28rpx 32rpx;border-bottom:1rpx solid rgba(62,39,35,0.05);transition:background 0.2s}
.contact-item:last-child{border-bottom:none}
.contact-item:active{background:rgba(212,164,90,0.06)}
.contact-icon{font-size:40rpx;margin-right:24rpx;line-height:1}
.contact-info{flex:1;display:flex;flex-direction:column;min-width:0}
.contact-label{font-size:22rpx;color:#9B8E85;display:block}
.contact-value{font-size:28rpx;color:#1A1A1A;font-weight:500;margin-top:6rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.contact-action{padding:8rpx 20rpx;font-size:24rpx;color:#D4A45A;border:1rpx solid #D4A45A;border-radius:9999rpx}

.section-title{font-size:24rpx;color:#9B8E85;letter-spacing:2rpx;padding:32rpx 32rpx 12rpx}

.time-card{background:#FFFFFF;margin:0 24rpx;border-radius:20rpx;padding:8rpx 32rpx;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.time-row{display:flex;justify-content:space-between;align-items:center;padding:24rpx 0;border-bottom:1rpx solid rgba(62,39,35,0.05)}
.time-row:last-child{border-bottom:none}
.time-day{font-size:26rpx;color:#1A1A1A}
.time-hour{font-size:26rpx;color:#D4A45A;font-weight:600}

.quick-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16rpx;padding:0 24rpx}
.quick-item{background:#FFFFFF;border-radius:16rpx;padding:24rpx 0;display:flex;flex-direction:column;align-items:center;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06);transition:transform 0.2s}
.quick-item:active{transform:scale(0.95);background:rgba(212,164,90,0.06)}
.quick-icon{font-size:40rpx;line-height:1;margin-bottom:8rpx}
.quick-label{font-size:22rpx;color:#5C5048}
