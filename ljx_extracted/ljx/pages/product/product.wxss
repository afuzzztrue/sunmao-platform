page{background:var(--color-bg,#F5F0E8)}

.container{padding:0;background:var(--color-bg,#F5F0E8);min-height:100vh;padding-bottom:160rpx}

.cover-wrap{position:relative;width:100%;height:560rpx;overflow:hidden}
.cover{width:100%;height:100%;display:block}
.cover-wrap::after{content:'';position:absolute;bottom:0;left:0;right:0;height:80rpx;background:linear-gradient(to top,var(--color-bg,#F5F0E8),transparent)}

.detail-card{background:var(--color-bg-card,#FFFFFF);margin:-60rpx 24rpx 30rpx;padding:40rpx 32rpx 36rpx;border-radius:var(--radius-lg,28rpx);box-shadow:var(--shadow-md,0 4rpx 16rpx rgba(62,39,35,0.10));position:relative;z-index:2}

.name-row{display:flex;align-items:flex-start;justify-content:space-between;gap:16rpx}
.name{font-size:40rpx;font-weight:700;color:var(--color-text,#1A1A1A);line-height:1.3;flex:1}

.price-block{display:flex;align-items:baseline;margin-top:28rpx}
.price-symbol{font-size:32rpx;color:var(--color-accent,#D4A45A);font-weight:600}
.price-value{font-size:56rpx;color:var(--color-accent,#D4A45A);font-weight:700;line-height:1}
.price-unit{font-size:26rpx;color:var(--color-accent,#D4A45A);margin-left:4rpx}

.stock-badge{display:inline-flex;align-items:center;padding:6rpx 20rpx;border-radius:var(--radius-round,9999rpx);font-size:24rpx;background:rgba(157,142,133,0.12);color:var(--color-text-secondary,#6B5E55);margin-top:20rpx}
.stock-badge.low{background:rgba(232,168,56,0.15);color:#C78A20}

.divider{height:1rpx;background:rgba(107,94,85,0.12);margin:28rpx 0}

.desc-label{font-size:26rpx;color:var(--color-text-muted,#9B8E85);margin-bottom:12rpx}
.desc{font-size:28rpx;color:var(--color-text-secondary,#6B5E55);line-height:1.9;text-align:justify}

.btn-buy{position:fixed;bottom:0;left:0;right:0;height:112rpx;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#3E2723,#4E342E);color:#FFFFFF;font-size:34rpx;font-weight:600;letter-spacing:4rpx;border-radius:0;border:none;padding:0;padding-bottom:env(safe-area-inset-bottom);z-index:100}
.btn-buy::after{border:none}

/* 7/1 新增: 下载课程按钮样式 */
.btn-download{background:linear-gradient(135deg,#2E7D32,#43A047)}
