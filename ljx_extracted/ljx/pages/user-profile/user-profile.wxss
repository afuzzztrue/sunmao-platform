.page {
  background: var(--color-bg, #F5F0E8);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-bg-card, #FFFFFF);
  margin: 24rpx;
  padding: 48rpx 32rpx;
  border-radius: 28rpx;
  box-shadow: var(--shadow-md, 0 4rpx 16rpx rgba(62, 39, 35, 0.10));
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #E5E0D8;
  margin-bottom: 24rpx;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text, #1A1A1A);
  margin-bottom: 24rpx;
}

.stats {
  display: flex;
  gap: 60rpx;
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text, #1A1A1A);
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted, #9B8E85);
  margin-top: 4rpx;
}

.follow-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #3E2723;
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 36rpx;
  border: none;
}

.follow-btn::after {
  border: none;
}

.follow-btn.following {
  background: #E5E0D8;
  color: #3E2723;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text, #1A1A1A);
  margin: 32rpx 24rpx 16rpx;
}

.works-list {
  padding: 0 24rpx;
}

.work-item {
  display: flex;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm, 0 2rpx 8rpx rgba(62, 39, 35, 0.06));
}

.work-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #E5E0D8;
  flex-shrink: 0;
}

.work-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.work-title {
  font-size: 30rpx;
  color: var(--color-text, #1A1A1A);
  font-weight: 500;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.work-meta {
  font-size: 24rpx;
  color: var(--color-text-muted, #9B8E85);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted, #9B8E85);
}
