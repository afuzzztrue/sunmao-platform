<!--pages/user-profile/user-profile.wxml-->
<view class="page">
  <view class="profile-card">
    <image class="avatar" src="{{user.avatar || '../images/kk.png'}}" mode="aspectFill" />
    <text class="nickname">{{user.nickname || '用户' + user.userId}}</text>
    <view class="stats">
      <view class="stat-item">
        <text class="stat-num">{{user.followCount || 0}}</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{user.followerCount || 0}}</text>
        <text class="stat-label">粉丝</text>
      </view>
    </view>
    <button wx:if="{{currentUserId && currentUserId !== user.userId}}" class="follow-btn {{isFollowing ? 'following' : ''}}" bindtap="onToggleFollow">{{isFollowing ? '已关注' : '+ 关注'}}</button>
  </view>

  <view class="section-title">TA 的作品</view>
  <view class="works-list" wx:if="{{works.length > 0}}">
    <view class="work-item" wx:for="{{works}}" wx:key="articleId" bindtap="goToArticle" data-id="{{item.articleId}}">
      <image class="work-cover" src="{{item.coverImage || '../images/技艺教程.png'}}" mode="aspectFill" />
      <view class="work-info">
        <text class="work-title">{{item.title}}</text>
        <text class="work-meta">{{item.viewCount || 0}} 浏览 · {{item.likeCount || 0}} 点赞</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && works.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-text">还没有发布作品</text>
  </view>
</view>
