page{background:#F5F0E8;min-height:100vh}
.subpage{padding-bottom:60rpx}

.subpage-header{display:flex;align-items:center;padding:24rpx 24rpx 20rpx;background:#FFFFFF;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.back-btn{width:60rpx;height:60rpx;display:flex;align-items:center;justify-content:center;font-size:48rpx;color:#1A1A1A;font-weight:300;line-height:1}
.btn-hover{opacity:0.5}
.subpage-title{flex:1;text-align:center;font-size:34rpx;font-weight:600;color:#1A1A1A;margin-right:-60rpx}

.section-title{font-size:24rpx;color:#9B8E85;letter-spacing:2rpx;padding:32rpx 32rpx 12rpx}

.faq-list{background:#FFFFFF;margin:0 24rpx;border-radius:20rpx;overflow:hidden;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.faq-item{border-bottom:1rpx solid rgba(62,39,35,0.05)}
.faq-item:last-child{border-bottom:none}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:24rpx 28rpx;transition:background 0.2s}
.faq-q:active{background:rgba(212,164,90,0.06)}
.faq-q-text{flex:1;font-size:28rpx;color:#1A1A1A;font-weight:500}
.faq-arrow{font-size:28rpx;color:#9B8E85;transition:transform 0.3s}
.faq-arrow.open{transform:rotate(180deg)}
.faq-a{padding:0 28rpx 24rpx;font-size:26rpx;color:#5C5048;line-height:1.7;letter-spacing:1rpx}

.feedback-card{background:#FFFFFF;margin:0 24rpx;border-radius:20rpx;padding:24rpx;box-shadow:0 2rpx 8rpx rgba(62,39,35,0.06)}
.feedback-input{width:100%;min-height:180rpx;font-size:26rpx;color:#1A1A1A;line-height:1.6;letter-spacing:1rpx}
.feedback-meta{text-align:right;margin-top:8rpx}
.feedback-count{font-size:22rpx;color:#9B8E85}
.feedback-contact{margin-top:16rpx;padding-top:16rpx;border-top:1rpx solid rgba(62,39,35,0.06)}
.feedback-contact-label{font-size:24rpx;color:#9B8E85;display:block;margin-bottom:12rpx}
.feedback-contact-input{width:100%;background:rgba(212,164,90,0.05);border-radius:12rpx;padding:16rpx 20rpx;font-size:26rpx;color:#1A1A1A;box-sizing:border-box}
.feedback-submit{margin-top:24rpx;background:linear-gradient(135deg,#D4A45A,#B8860B);color:#FFFFFF;text-align:center;padding:24rpx;border-radius:9999rpx;font-size:30rpx;font-weight:600;letter-spacing:4rpx;box-shadow:0 4rpx 12rpx rgba(212,164,90,0.3)}
