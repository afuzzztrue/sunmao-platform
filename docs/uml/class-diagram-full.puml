@startuml class-diagram-full
' 榫卯非遗文化传承平台 - 完整后端类图
' 包含：18 Controller + 15 Service 接口 + 17 Mapper + 16 Entity + Common
' 注意：因类数量较多，本图采用按层分组布局，方法已精简核心接口
' 生成方式：IDEA PlantUML 插件 → Preview → 导出 PNG（建议横向长图）

title 榫卯非遗文化传承平台 - 后端完整类图

skinparam linetype ortho
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

' ========== Common ==========
package "common" {
    class Result<T> {
        +code: Integer
        +message: String
        +data: T
        +success(T): Result<T>
        +error(String): Result<T>
    }
    class PageResult<T> {
        +total: Long
        +records: List<T>
    }
}

' ========== Entity ==========
package "entity" {
    class User {
        -userId: Integer
        -openid: String
        -unionid: String
        -nickname: String
        -avatar: String
        -phone: String
        -email: String
        -password: String
        -gender: Integer
        -province: String
        -city: String
        -studyHours: Integer
        -userType: Integer
        -status: Integer
        -preferences: String
        -createTime: LocalDateTime
        -updateTime: LocalDateTime
    }
    class Article {
        -articleId: Integer
        -categoryId: Integer
        -userId: Integer
        -title: String
        -content: String
        -coverImage: String
        -images: String
        -viewCount: Integer
        -likeCount: Integer
        -collectCount: Integer
        -commentCount: Integer
        -isHot: Integer
        -isBanner: Integer
        -sortOrder: Integer
        -status: Integer
        -createTime: LocalDateTime
        -updateTime: LocalDateTime
    }
    class Post {
        -postId: Integer
        -userId: Integer
        -title: String
        -content: String
        -likeCount: Integer
        -commentCount: Integer
        -shareCount: Integer
        -postType: Integer
        -status: Integer
        -createTime: LocalDateTime
        -updateTime: LocalDateTime
    }
    class UserWork {
        -workId: Integer
        -userId: Integer
        -title: String
        -description: String
        -images: String
        -categoryId: Integer
        -viewCount: Integer
        -likeCount: Integer
        -commentCount: Integer
        -collectCount: Integer
        -status: Integer
        -createTime: LocalDateTime
        -updateTime: LocalDateTime
    }
    class Course {
        -courseId: Integer
        -categoryId: Integer
        -userId: Integer
        -title: String
        -description: String
        -coverImage: String
        -videoUrl: String
        -price: BigDecimal
        -duration: Integer
        -difficulty: Integer
        -viewCount: Integer
        -likeCount: Integer
        -downloadCount: Integer
        -sortOrder: Integer
        -status: Integer
        -createTime: LocalDateTime
        -updateTime: LocalDateTime
    }
    class Product {
        -productId: Integer
        -productName: String
        -categoryId: Integer
        -price: BigDecimal
        -coverImage: String
        -description: String
        -stock: Integer
        -status: Integer
        -createTime: LocalDateTime
    }
    class ProductOrder {
        -orderId: Integer
        -productId: Integer
        -productName: String
        -userId: Integer
        -quantity: Integer
        -totalPrice: BigDecimal
        -status: Integer
