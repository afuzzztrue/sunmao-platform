' ========== Mapper ==========
package "mapper" {
    interface UserMapper {
        +selectByOpenid(String): User
        +selectByPhone(String): User
        +selectByEmail(String): User
        +selectPreferences(Integer): String
        +updatePreferences(Integer, String): int
    }
    interface ArticleMapper {
        +selectHotList(Integer): List<Article>
        +selectByCategoryId(Integer): List<Article>
        +incrementViewCount(Integer): int
        +updateLikeCount(Integer, Integer): int
        +updateCollectCount(Integer, Integer): int
        +updateCommentCount(Integer, Integer): int
    }
    interface PostMapper {
        +selectPageList(Integer, Integer): List<Post>
        +selectByUserId(Integer): List<Post>
        +updateLikeCount(Integer, Integer): int
        +updateCommentCount(Integer, Integer): int
    }
    interface UserWorkMapper {
        +selectByUserId(Integer): List<UserWork>
    }
    interface CourseMapper {
        +selectByCategoryId(Integer): List<Course>
        +selectByDifficulty(Integer): List<Course>
        +incrementViewCount(Integer): int
        +incrementDownloadCount(Integer): int
    }
    interface ProductMapper
    interface ProductOrderMapper
    interface CourseDownloadMapper {
        +selectByUserAndCourse(Integer, Integer): CourseDownload
        +selectUserDownloadsWithCourse(Integer, Integer): List<Map>
    }
    interface CategoryMapper {
        +selectByParentId(Integer): List<Category>
    }
    interface BannerMapper {
        +selectActiveList(): List<Banner>
    }
    interface CommentMapper {
        +selectRootComments(Integer, Integer): List<Comment>
        +selectReplies(Integer): List<Comment>
    }
    interface LikeRecordMapper {
        +selectByUserAndTarget(Integer, Integer, Integer): LikeRecord
        +selectMyLikes(Integer, Integer): List<Map>
        +selectMyLikesEnriched(Integer, Integer): List<Map>
    }
    interface CollectRecordMapper {
        +selectByUserAndArticle(Integer, Integer): CollectRecord
        +selectByUserAndTarget(Integer, Integer, Integer): CollectRecord
        +selectMyCollectsEnriched(Integer, Integer): List<Map>
    }
    interface FootprintMapper {
        +selectMyFootprintsEnriched(Integer, Integer): List<Map>
    }
    interface FollowMapper {
        +selectByUserAndTarget(Integer, Integer): Follow
        +selectFollowCount(Integer): Integer
        +selectFollowerCount(Integer): Integer
    }
    interface SearchMapper {
        +globalSearch(String, Integer): List<Map>
    }
    interface FeedbackMapper
}

' ========== Service ==========
package "service" {
    interface UserService {
        +getByOpenid(String): User
        +getByPhone(String): User
        +getByEmail(String): User
        +wxLogin(String, String, String, String): User
        +register(String, String, String, String): User
        +login(String, String): User
        +updateStudyHours(Integer, Integer): void
        +getPreferences(Integer): String
        +updatePreferences(Integer, String): void
    }
    interface ArticleService {
        +getHotList(Integer): List<Article>
        +getListByCategory(Integer): List<Article>
        +getDetail(Integer): Article
        +incrementViewCount(Integer): void
        +toggleLike(Integer, Integer): void
        +toggleCollect(Integer, Integer): void
        +toggleLikeAndReturn(Integer, Integer): boolean
        +toggleCollectAndReturn(Integer, Integer): boolean
        +create(Article): Integer
    }
    interface PostService {
        +getPostList(Integer, Integer): List<Post>
        +getUserPosts(Integer): List<Post>
        +toggleLike(Integer, Integer): void
    }
    interface UserWorkService {
        +getUserWorks(Integer): List<UserWork>
    }
    interface CourseService {
        +getCoursesByCategory(Integer): List<Course>
        +getCoursesByDifficulty(Integer): List<Course>
        +recordDownload(Integer, Integer): void
        +getUserDownloads(Integer, Integer): List<Map>
    }
    interface ProductService
    interface ProductOrderService
    interface CourseDownloadService
    interface CategoryService {
        +getAllCategories(): List<Category>
        +getCategoriesByParentId(Integer): List<Category>
    }
    interface BannerService {
        +getActiveBanners(): List<Banner>
    }
    interface CommentService
    interface LikeService {
        +myLikes(Integer, Integer): List<Map>
    }
    interface CollectService {
        +myCollects(Integer, Integer): List<Map>
    }
    interface FootprintService {
        +getUserFootprints(Integer, Integer): List<Footprint>
        +addFootprint(Integer, Integer, Integer, Integer): void
    }
    interface FollowService {
        +toggleFollow(Integer, Integer): void
        +getFollowCount(Integer): Integer
        +getFollowerCount(Integer): Integer
    }
    interface SearchService {
        +globalSearch(String, Integer): List<Map>
    }
    interface FeedbackService {
        +submit(Feedback): void
        +pageQuery(Integer, Integer, Integer, Integer): IPage<Feedback>
    }
    interface ChatService
}

' ========== Controller ==========
package "controller" {
    class UserController {
        +register(String, String, String, String): Result<User>
        +login(String, String): Result<Map>
        +wxLogin(String, String, String, String): Result<Map>
        +getUserInfo(Integer): Result<Map>
        +updateUser(User): Result<Void>
        +getPreferences(Integer): Result<String>
        +updatePreferences(Integer, String): Result<Void>
    }
    class ArticleController {
        +getHotList(Integer): Result<List<Article>>
        +getListByCategory(Integer): Result<List<Article>>
        +getDetail(Integer): Result<Article>
        +toggleLike(Integer, Integer): Result<Map>
        +toggleCollect(Integer, Integer): Result<Map>
        +getUserStatus(Integer, Integer): Result<Map>
        +create(Article): Result<Map>
    }
    class PostController {
        +getPostList(Integer, Integer): Result<List<Post>>
        +getUserPosts(Integer): Result<List<Post>>
        +publishPost(Post): Result<Void>
        +toggleLike(Integer, Integer): Result<Void>
    }
    class UserWorkController {
        +getUserWorks(Integer): Result<List<UserWork>>
        +publishWork(UserWork): Result<Void>
    }
    class CourseController {
        +getCoursesByCategory(Integer): Result<List<Course>>
        +getCoursesByDifficulty(Integer): Result<List<Course>>
        +recordDownload(Integer, Integer): Result<Void>
        +getUserDownloads(Integer, Integer): Result<List<Map>>
    }
    class ProductController {
        +list(Integer): Result<List<Product>>
        +detail(Integer): Result<Product>
        +search(String): Result<List<Product>>
        +createOrder(Integer, Integer, Integer): Result<ProductOrder>
        +myOrders(Integer): Result<List<ProductOrder>>
        +cancelOrder(Integer, Integer): Result<String>
        +deleteOrder(Integer, Integer): Result<String>
    }
    class CategoryController {
        +getAllCategories(): Result<List<Category>>
    }
    class BannerController {
        +getActiveBanners(): Result<List<Banner>>
    }
    class CommentController
    class LikeController {
        +myLikes(Integer, Integer): Result<List<Map>>
    }
    class CollectController {
        +myCollects(Integer, Integer): Result<List<Map>>
    }
    class FootprintController {
        +getUserFootprints(Integer, Integer): Result<List<Footprint>>
        +myFootprints(Integer, Integer): Result<List<Map>>
        +addFootprint(Integer, Integer, Integer, Integer): Result<Void>
    }
    class FollowController {
        +toggleFollow(Integer, Integer): Result<Void>
        +getFollowCount(Integer): Result<Map>
    }
    class SearchController {
        +global(String, Integer): Result<List<Map>>
    }
    class FeedbackController {
        +submit(Feedback, HttpServletRequest): Result<Void>
        +list(Integer, Integer, Integer, Integer): Result<IPage<Feedback>>
    }
    class ChatController {
        +query(String, String): Result<Map>
    }
    class AdminController {
        +userList(Integer, Integer): Result<Map>
        +userSearch(String): Result<List<User>>
        +userAdd(String, String, String): Result<User>
        +userUpdate(User): Result<Void>
        +userDelete(Integer): Result<Void>
    }
    class UploadController {
        +upload(MultipartFile[]): Result<List<String>>
    }
    class UploadFileController {
        +serveFile(String, String): ResponseEntity<Resource>
    }
}

