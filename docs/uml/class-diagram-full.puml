    class Category {
        -categoryId: Integer
        -name: String
        -parentId: Integer
        -sortOrder: Integer
        -icon: String
        -description: String
        -status: Integer
        -createTime: LocalDateTime
    }
    class Banner {
        -bannerId: Integer
        -title: String
        -imageUrl: String
        -linkUrl: String
        -linkType: Integer
        -linkId: Integer
        -sortOrder: Integer
        -status: Integer
